# ============================================
# LovTrip Streamlit Secrets 配置模板
# 复制此文件为 secrets.toml 并填入你的 API Key
# cp secrets.toml.example secrets.toml
# ============================================
# 注意: secrets.toml 已被 .gitignore 忽略，请勿提交到 Git

# LLM API 配置 (TokenHub / OpenAI 兼容接口)
OPENAI_API_KEY = "your_openai_api_key_here"
OPENAI_BASE_URL = "https://tokenhub.tencentmaas.com/v1/"
MODEL_NAME = "kimi-k2.7-code"

# 百度地图 API Key
# 申请地址: https://lbsyun.baidu.com/apiconsole/key
BAIDU_MAP_AK = "your_baidu_map_ak_here"

# Pexels 图片 API Key (可选)
# 申请地址: https://www.pexels.com/api/
PEXELS_API_KEY = "your_pexels_api_key_here"
