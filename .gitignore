# ============================================
# LovTrip .gitignore
# ============================================

# Streamlit secrets (DO NOT COMMIT)
.streamlit/secrets.toml

# Environment variables (DO NOT COMMIT)
.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# Virtual environment
venv/
.venv/
env/
lib/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
.DS_Store

# Logs
*.log

# Testing
.pytest_cache/
htmlcov/
.coverage

# Output files (AI generated trip plans)
*_行程规划.txt
*_行程.txt

# Jupyter
.ipynb_checkpoints/

# Misc
*.bak
